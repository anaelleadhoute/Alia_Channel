# ─── Server ───────────────────────────────────────────────────────────
DOMAIN=alia-channel.com
SERVER_IP=                        # Fill after Hetzner setup

# ─── n8n ──────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=                     # Choose a strong password
N8N_ENCRYPTION_KEY=               # Random 32-char string

# ─── Anthropic (Claude Haiku) ─────────────────────────────────────────
ANTHROPIC_API_KEY=                # console.anthropic.com

# ─── Whapi.Cloud ──────────────────────────────────────────────────────
WHAPI_API_KEY=                    # From Whapi.Cloud dashboard
WHAPI_CHANNEL_ID=                 # Your channel ID
WHAPI_FR_GROUP_ID=                # AL.IA FR group ID
WHAPI_RU_GROUP_ID=                # AL.IA RU group ID

# ─── Instagram (Phase 7 - later) ──────────────────────────────────────
META_ACCESS_TOKEN=
META_IG_ACCOUNT_ID=

# ─── Alerts ───────────────────────────────────────────────────────────
ALERT_EMAIL=                      # Your email for error alerts
TELEGRAM_BOT_TOKEN=               # Optional: Telegram alert bot
TELEGRAM_CHAT_ID=                 # Optional: your Telegram chat ID

# ─── App ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
SCRAPE_INTERVAL_HOURS=3
